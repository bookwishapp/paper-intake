# Square API Credentials - REQUIRED for Square catalog integration
# Get from https://developer.squareup.com/
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# Note: UPCitemDB uses a free tier endpoint - no API key needed!